# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rideshare_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_48_CHARS_RANDOM_STRING
JWT_EXPIRE=7d

# Admin account creation secret — keep strong and private
ADMIN_SECRET=CHANGE_ME_STRONG_ADMIN_SECRET

# ── Redis (token blacklist & cache) ───────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_URL=redis://user:password@host:6379   ← use for cloud Redis

# ── CORS — comma-separated list of allowed origins ────────────────────────────
ALLOWED_ORIGINS=https://admin.ombiaexpress.com,https://app.ombiaexpress.com

# ── Business Rules ─────────────────────────────────────────────────────────────
COMMISSION_RATE=0.15
BOOKING_FEE=0.10
APP_NAME=Ombia Express

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
