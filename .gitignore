# Dependencies
node_modules/
**/node_modules/

# Environment secrets — NEVER commit
.env
**/.env
.env.local
.env.production
.env.*.local

# Build output
admin/dist/
mobile/dist/
web-build/

# Expo
.expo/
.expo-shared/

# Logs
*.log
**/logs/

# Uploads (user-generated content, not source code)
server/uploads/

# OS files
.DS_Store
Thumbs.db

# Temp / generated scripts (not source code)
write_deploy.js
generate_pdfs.js
presentation_word.js
nul
~$*

# Large binary / media files not needed in repo
*.pdf
*.docx
*.png
*.jpg
*.jpeg

